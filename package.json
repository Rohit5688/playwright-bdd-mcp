{
  "name": "testforge",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/tests/",
    "build:macos": "pkg . --targets node18-macos-arm64,node18-macos-x64 --out-path binaries",
    "build:win": "pkg . --targets node18-win-x64 --out-path binaries"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js",
      "node_modules/@modelcontextprotocol/sdk/dist/**/*.js"
    ],
    "assets": [
      "dist/**/*"
    ]
  },
  "bin": {
    "testforge": "./dist/index.js"
  },
  "description": "Enterprise-grade MCP Server that transforms your LLM into a Staff-Level QA Automation Engineer for Playwright-BDD.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "bdd",
    "automation",
    "ai",
    "qa",
    "testing"
  ],
  "author": "ForgeTest AI",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rohit5688/TestForge.git"
  },
  "bugs": {
    "url": "https://github.com/Rohit5688/TestForge/issues"
  },
  "homepage": "https://github.com/Rohit5688/TestForge#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "playwright": "^1.58.2",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "pkg": "^5.8.1",
    "playwright-bdd": "^8.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}